# UBT POS - Environment Variables Template
# MUHIM: Bu faylni .env.local ga nusxalang va haqiqiy qiymatlarni kiriting

# ─── Authentication ──────────────────────────────────
# JWT Secret — kassir login token imzolash uchun
# MUHIM: Minimal 32 ta tasodifiy belgi bo'lishi kerak
# Generator: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS

# ─── Database ────────────────────────────────────────
# Ishlab chiqarish muhitida PostgreSQL yoki MySQL ishlatish tavsiya etiladi
DATABASE_URL="file:./dev.db"

# ─── Environment ─────────────────────────────────────
NODE_ENV=development

# ─── Optional: Tashqi Xizmatlar ──────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# SMS_API_KEY=your-sms-api-key
# SMS_SENDER=YourBrand
